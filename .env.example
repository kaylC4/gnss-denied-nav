# Copia questo file in .env e compila i valori reali
# Il file .env NON deve mai essere committato (è in .gitignore)

# ── Google Maps / Earth API ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_EARTH_ENGINE_KEY=your_gee_service_account_key_path

# ── Mapbox (alternativa satellite tiles) ────────────────────────────────────
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# ── OpenAerialMap (tile satellite open) ──────────────────────────────────────
OAM_API_KEY=your_oam_key_here

# ── MUN-FRL dataset path ─────────────────────────────────────────────────────
MUN_FRL_DATA_DIR=/path/to/mun_frl_dataset

# ── DEM (quota terreno) ──────────────────────────────────────────────────────
SRTM_DATA_DIR=/path/to/srtm_tiles
COPERNICUS_DEM_DIR=/path/to/copernicus_dem

# ── Encoder weights ──────────────────────────────────────────────────────────
ENCODER_WEIGHTS_DIR=/path/to/weights
